# ─────────────────────────────────────────────────────────────
#  AI Tools Set — backend environment variables
# ─────────────────────────────────────────────────────────────
#  Copy this file to `.env.local` and fill in the values.
#  Never commit `.env.local` — it's gitignored.
# ─────────────────────────────────────────────────────────────

# --- Public site URL ----------------------------------------
SITE_URL="http://localhost:3000"

# --- Database (Neon Postgres) -------------------------------
DATABASE_URL=""

# --- NextAuth.js v5 -----------------------------------------
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# --- Email magic links (Resend) -----------------------------
RESEND_API_KEY=""
EMAIL_FROM=""

# --- Google OAuth (optional) --------------------------------
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- AI provider ---------------------------------------------
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""

# --- Cron secret --------------------------------------------
CRON_SECRET=""

# --- Admin allowlist ----------------------------------------
ADMIN_EMAILS=""

# --- CMS image hosting (Vercel Blob) ------------------------
BLOB_READ_WRITE_TOKEN=""
