# ─────────────────────────────────────────────────────────────
#  AI Tools Set — backend environment variables
# ─────────────────────────────────────────────────────────────
#  Copy this file to `.env.local` and fill in the values.
#  Never commit `.env.local` — it's gitignored.
# ─────────────────────────────────────────────────────────────

# --- Public site URL ----------------------------------------
SITE_URL="http://localhost:3000"

# --- Database (Neon Postgres) -------------------------------
DATABASE_URL=""

# --- NextAuth.js v5 -----------------------------------------
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# --- Email magic links (Resend) -----------------------------
RESEND_API_KEY=""
EMAIL_FROM=""

# --- Google OAuth (optional) --------------------------------
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- AI provider ---------------------------------------------
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""

# --- Cron secret --------------------------------------------
CRON_SECRET=""

# --- Admin allowlist ----------------------------------------
ADMIN_EMAILS=""

# --- CMS image hosting (Vercel Blob) ------------------------
BLOB_READ_WRITE_TOKEN=""

# --- Cloudflare Turnstile (bot challenge — free) ------------
# Sign up at https://www.cloudflare.com → Turnstile → Add a site
# Pick "Managed" widget mode for invisible challenges.
# The site key is public (NEXT_PUBLIC_ prefix); the secret is server-only.
# When both env vars are unset, the widget renders as a no-op and the
# server verification returns true — feature is fully dark in dev.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- Sentry (error monitoring — free 5k events/mo) ----------
# Sign up at https://sentry.io, create a Next.js project, copy the DSN.
# Unset = Sentry is fully dark (no-op init).
NEXT_PUBLIC_SENTRY_DSN=""
# Optional: server-only DSN if you want client / server in separate projects.
SENTRY_DSN=""
