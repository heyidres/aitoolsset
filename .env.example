# ─────────────────────────────────────────────────────────────
#  AI Tools Set — backend environment variables
# ─────────────────────────────────────────────────────────────
#  Copy this file to `.env.local` and fill in the values.
#  Never commit `.env.local` — it's gitignored.
# ─────────────────────────────────────────────────────────────

# --- Public site URL ----------------------------------------
SITE_URL="http://localhost:3000"

# --- Database (Neon Postgres) -------------------------------
DATABASE_URL=""

# --- NextAuth.js v5 -----------------------------------------
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# --- Email magic links (Resend) -----------------------------
RESEND_API_KEY=""
EMAIL_FROM=""

# --- Google OAuth (optional) --------------------------------
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- AI providers (cascading fallback) -----------------------
# Order of priority: Gemini → Groq → Anthropic. The first one whose
# key is set is tried first; on a quota / rate-limit / auth failure
# the next configured provider is tried automatically.
#
# Both Gemini and Groq are FREE top-tier — set BOTH for redundancy.
#
# Gemini 2.5 Flash: 1,500 req/day free | https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Groq Llama 3.3 70B: 14,400 req/day free | https://console.groq.com/keys
GROQ_API_KEY=""
# Anthropic Claude Haiku: paid (~$0.005/call) | https://console.anthropic.com
ANTHROPIC_API_KEY=""

# --- Cron secret --------------------------------------------
CRON_SECRET=""

# --- Admin allowlist ----------------------------------------
ADMIN_EMAILS=""

# --- CMS image hosting (Vercel Blob) ------------------------
BLOB_READ_WRITE_TOKEN=""

# --- Cloudflare Turnstile (bot challenge — free) ------------
# Sign up at https://www.cloudflare.com → Turnstile → Add a site
# Pick "Managed" widget mode for invisible challenges.
# The site key is public (NEXT_PUBLIC_ prefix); the secret is server-only.
# When both env vars are unset, the widget renders as a no-op and the
# server verification returns true — feature is fully dark in dev.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- Sentry (error monitoring — free 5k events/mo) ----------
# Sign up at https://sentry.io, create a Next.js project, copy the DSN.
# Unset = Sentry is fully dark (no-op init).
NEXT_PUBLIC_SENTRY_DSN=""
# Optional: server-only DSN if you want client / server in separate projects.
SENTRY_DSN=""
